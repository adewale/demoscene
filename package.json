{
  "name": "demoscene",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local",
    "build": "wrangler deploy --dry-run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:worker": "vitest run --config vitest.worker.config.ts",
    "test:e2e": "playwright test",
    "coverage:unit": "vitest run --config vitest.unit.config.ts --coverage",
    "coverage:worker": "vitest run --config vitest.worker.config.ts --coverage",
    "coverage": "npm run coverage:unit && npm run coverage:worker",
    "audit:deps": "npm audit --audit-level=high",
    "audit:dead-code": "knip",
    "audit:duplicates": "jscpd --threshold 1 src tests --ignore \"**/migrations/**\"",
    "audit:secrets": "secretlint \"**/*\"",
    "test:fast": "npm run format && npm run lint && npm run typecheck && npm run test:unit && npm run test:worker",
    "test:full": "npm run test:fast && npm run test:e2e && npm run coverage && npm run audit:deps && npm run audit:dead-code && npm run audit:duplicates && npm run audit:secrets",
    "db:migrate:local": "wrangler d1 migrations apply DB --local --config wrangler.jsonc",
    "db:seed:e2e": "wrangler d1 execute DB --local --file tests/e2e/seed.sql --config wrangler.jsonc",
    "e2e:prepare": "npm run db:migrate:local && npm run db:seed:e2e"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "hono": "^4.8.5",
    "jsonc-parser": "^3.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "smol-toml": "^1.4.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.6",
    "@cloudflare/workers-types": "^4.20260405.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.52.0",
    "@secretlint/secretlint-rule-preset-recommend": "^11.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "@vitest/coverage-istanbul": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/runner": "^4.1.4",
    "@vitest/snapshot": "^4.1.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.25.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-security": "^3.0.1",
    "fast-check": "^4.1.1",
    "jscpd": "^4.0.5",
    "jsdom": "^26.1.0",
    "knip": "^5.51.1",
    "prettier": "^3.5.3",
    "secretlint": "^11.4.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4",
    "wrangler": "^4.82.2"
  }
}
