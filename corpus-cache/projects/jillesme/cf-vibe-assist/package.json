{
	"name": "vibe-assist",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 3000",
		"build": "vite build",
		"preview": "pnpm run build && vite preview",
		"test": "vitest run",
		"deploy": "pnpm run build && wrangler deploy",
		"cf-typegen": "wrangler types",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply vibe-assist-db --local",
		"db:migrate:remote": "wrangler d1 migrations apply vibe-assist-db --remote"
	},
	"dependencies": {
		"@cloudflare/kumo": "^1.6.0",
		"@cloudflare/stream-react": "^1.9.3",
		"@cloudflare/vite-plugin": "^1.25.1",
		"@tailwindcss/vite": "^4.2.0",
		"@tanstack/react-devtools": "^0.9.6",
		"@tanstack/react-router": "^1.161.1",
		"@tanstack/react-router-devtools": "^1.161.1",
		"@tanstack/react-router-ssr-query": "^1.161.1",
		"@tanstack/react-start": "^1.161.1",
		"@tanstack/router-plugin": "^1.161.1",
		"drizzle-orm": "^0.45.1",
		"jose": "^6.1.3",
		"jsonrepair": "^3.13.2",
		"lucide-react": "^0.574.0",
		"nanoid": "^5.1.6",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwindcss": "^4.2.0",
		"typewriter-effect": "^2.22.0",
		"vite-tsconfig-paths": "^6.1.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@tanstack/devtools-vite": "^0.5.1",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^25.2.3",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.4",
		"drizzle-kit": "^0.31.9",
		"jsdom": "^28.1.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.0.18",
		"wrangler": "^4.66.0"
	}
}