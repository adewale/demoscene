{
	"name": "tanstack-durable-object-starter",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 3000",
		"build": "vite build",
		"serve": "vite preview",
		"test": "vitest run",
		"deploy": "pnpm run build && wrangler deploy",
		"preview": "pnpm run build && vite preview",
		"db:generate": "pnpm drizzle-kit generate --config=drizzle.config.ts",
		"db:generate:do": "pnpm drizzle-kit generate --config=drizzle-do.config.ts",
		"db:migrate": "pnpm wrangler d1 migrations apply DB",
		"cf-typegen": "wrangler types"
	},
	"dependencies": {
		"@cloudflare/vite-plugin": "^1.25.2",
		"@tailwindcss/vite": "^4.2.1",
		"@tanstack/react-devtools": "^0.9.6",
		"@tanstack/react-router": "^1.162.4",
		"@tanstack/react-router-devtools": "^1.162.4",
		"@tanstack/react-router-ssr-query": "^1.162.4",
		"@tanstack/react-start": "^1.162.4",
		"@tanstack/router-plugin": "^1.162.4",
		"drizzle-orm": "^0.45.1",
		"lucide-react": "^0.575.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"tailwindcss": "^4.2.1",
		"vite-tsconfig-paths": "^6.1.1"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.12.14",
		"@tanstack/devtools-vite": "^0.5.1",
		"@testing-library/dom": "^10.4.0",
		"@testing-library/react": "^16.2.0",
		"@types/node": "^25.3.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.0",
		"@vitejs/plugin-react": "^5.1.4",
		"drizzle-kit": "^0.31.9",
		"jsdom": "^28.1.0",
		"typescript": "^5.7.2",
		"vite": "^7.1.7",
		"vitest": "^3.2.4",
		"web-vitals": "^5.1.0",
		"wrangler": "^4.67.0"
	}
}
