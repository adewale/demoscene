{
  "name": "bobbin",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:real": "vitest run --config vitest.node.config.ts",
    "test:visual": "playwright test e2e/visual.spec.ts --project=desktop --workers=1",
    "test:all": "vitest run && vitest run --config vitest.node.config.ts",
    "characterize:pipeline:naive": "node scripts/characterize-pipeline.mjs naive",
    "characterize:pipeline:yaket": "node scripts/characterize-pipeline.mjs yaket",
    "characterize:pipeline:yaket_bobbin": "node scripts/characterize-pipeline.mjs yaket_bobbin",
    "characterize:pipeline:episode_hybrid": "node scripts/characterize-pipeline.mjs episode_hybrid",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "types": "wrangler types"
  },
  "dependencies": {
    "@ade_oshineye/yaket": "^0.4.0",
    "hono": "^4.12.11"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.1",
    "@cloudflare/workers-types": "^4.20260405.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "agent-browser": "^0.25.3",
    "fast-check": "^4.6.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "wrangler": "^4.80.0"
  }
}
